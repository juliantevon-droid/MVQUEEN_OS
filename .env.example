# ==============================================================================
# MVQUEEN_OS ENVIRONMENT CONFIGURATION
# ==============================================================================
# INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Fill in all values marked with YOUR_*
# 3. NEVER commit .env to version control
# 4. Add .env to .gitignore
# 5. For GitHub Actions: add these as repository secrets
# ==============================================================================

# ==============================================================================
# 1. RUNTIME ENVIRONMENT
# ==============================================================================
# Options: "dev", "staging", "prod"
ENVIRONMENT=dev

# Python logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=DEBUG

# Enable debug mode (more verbose output)
DEBUG=True

# ==============================================================================
# 2. SHOPIFY CONFIGURATION
# ==============================================================================
# Get these from: https://shopify.dev/apps/build

# Your Shopify store domain (e.g., mystore.myshopify.com)
SHOPIFY_STORE_DOMAIN=YOUR_SHOPIFY_STORE.myshopify.com

# Shopify API version (use stable version, e.g., 2024-10)
SHOPIFY_API_VERSION=2024-10

# Get from Shopify Admin → Apps and integrations → App and sales channel settings
SHOPIFY_API_KEY=YOUR_SHOPIFY_API_KEY

# Private app password (keep this SECRET)
SHOPIFY_API_PASSWORD=YOUR_SHOPIFY_API_PASSWORD

# Access token for custom app (if using OAuth)
SHOPIFY_ACCESS_TOKEN=shpat_XXXXXXXXXXXXXXXXXXXXX

# Webhook signing secret (for verifying webhook authenticity)
SHOPIFY_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET

# ==============================================================================
# 3. DATABASE CONFIGURATION
# ==============================================================================
# SQLite (development)
DATABASE_URL=sqlite:///mvqueen.db

# PostgreSQL (production)
# DATABASE_URL=postgresql://user:password@localhost:5432/mvqueen

# Database pool settings
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_RECYCLE=3600

# ==============================================================================
# 4. AWS CONFIGURATION (for S3 storage, if using)
# ==============================================================================
# AWS region
AWS_REGION=us-east-1

# AWS access key ID
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY

# AWS secret access key
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_KEY

# S3 bucket for product images
AWS_S3_BUCKET=mvqueen-products

# S3 bucket for backups
AWS_S3_BACKUP_BUCKET=mvqueen-backups

# ==============================================================================
# 5. SECURITY & SECRETS
# ==============================================================================
# A secret key for session encryption (generate: openssl rand -hex 32)
SECRET_KEY=YOUR_RANDOM_SECRET_KEY_HERE

# JWT secret for API authentication
JWT_SECRET=YOUR_JWT_SECRET_KEY_HERE

# ==============================================================================
# 6. EMAIL CONFIGURATION
# ==============================================================================
# Email provider: "smtp", "sendgrid", "mailgun"
EMAIL_PROVIDER=smtp

# SMTP settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# SendGrid API key (if using SendGrid)
SENDGRID_API_KEY=YOUR_SENDGRID_API_KEY

# Mailgun settings (if using Mailgun)
MAILGUN_API_KEY=YOUR_MAILGUN_API_KEY
MAILGUN_DOMAIN=YOUR_MAILGUN_DOMAIN

# Default sender email
DEFAULT_FROM_EMAIL=noreply@mvqueen.com

# ==============================================================================
# 7. MONITORING & ERROR TRACKING
# ==============================================================================
# Sentry DSN for error tracking
SENTRY_DSN=https://YOUR_KEY@sentry.io/YOUR_PROJECT_ID

# Sentry environment
SENTRY_ENVIRONMENT=dev

# ==============================================================================
# 8. ANALYTICS & TRACKING
# ==============================================================================
# Google Analytics 4 property ID
GA4_PROPERTY_ID=G-YOUR_PROPERTY_ID

# Google Ads conversion ID
GOOGLE_ADS_CONVERSION_ID=YOUR_CONVERSION_ID

# Facebook Pixel ID
FACEBOOK_PIXEL_ID=YOUR_PIXEL_ID

# ==============================================================================
# 9. PAYMENT PROCESSING
# ==============================================================================
# Stripe public key
STRIPE_PUBLIC_KEY=pk_live_YOUR_PUBLIC_KEY

# Stripe secret key
STRIPE_SECRET_KEY=sk_live_YOUR_SECRET_KEY

# Stripe webhook secret
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# ==============================================================================
# 10. EXTERNAL APIs
# ==============================================================================
# OpenAI API key (for content generation)
OPENAI_API_KEY=sk-YOUR_OPENAI_API_KEY

# Anthropic API key (for Claude)
ANTHROPIC_API_KEY=sk-ant-YOUR_ANTHROPIC_KEY

# ==============================================================================
# 11. FEATURE FLAGS
# ==============================================================================
# Enable/disable features for gradual rollout
FEATURE_EMAIL_NOTIFICATIONS=True
FEATURE_SMS_NOTIFICATIONS=False
FEATURE_AI_PRODUCT_DESCRIPTIONS=True
FEATURE_PERSONALIZATION_ENGINE=False
FEATURE_LOYALTY_PROGRAM=False

# ==============================================================================
# 12. RATE LIMITING & PERFORMANCE
# ==============================================================================
# Requests per minute for API endpoints
RATE_LIMIT_RPS=100

# Shopify API call limit (calls per second)
SHOPIFY_API_RATE_LIMIT=2

# Cache TTL in seconds
CACHE_TTL_PRODUCTS=3600
CACHE_TTL_COLLECTIONS=7200
CACHE_TTL_CUSTOMERS=1800

# ==============================================================================
# 13. BACKUP & MAINTENANCE
# ==============================================================================
# Enable automated daily backups
BACKUP_ENABLED=True

# Backup retention period in days
BACKUP_RETENTION_DAYS=30

# Time to run backups (24-hour format, UTC)
BACKUP_SCHEDULE=02:00

# ==============================================================================
# 14. BRAND & CONTENT CONFIGURATION
# ==============================================================================
# Brand names
BRAND_NAME=MVQUEEN
SISTER_BRAND_NAME=Miss.Princess

# Color system (from 02_Brand_Identity/color_system.md)
BRAND_PRIMARY_BG=#FAF6F0
BRAND_PRIMARY_ACCENT=#F2D4CC
BRAND_SECONDARY_ACCENT=#C9968A
BRAND_NEUTRAL_SUPPORT=#C4B5A5
BRAND_TYPOGRAPHY=#3B2314
BRAND_SECONDARY_TEXT=#4A4240
BRAND_LUXURY_ACCENT=#D4AF78

# Typography (from 02_Brand_Identity/typography_system.md)
FONT_DISPLAY=Cormorant Garamond
FONT_BODY=Jost
FONT_SIZE_BASE=16

# Product configuration
PRODUCT_CATEGORIES=skincare,fragrance,fashion,haircare,beauty,jewelry,shoes
ENABLE_MISS_PRINCESS_PRODUCTS=True

# ==============================================================================
# 15. AI & CONTENT GENERATION
# ==============================================================================
# AI model for product descriptions
AI_MODEL=claude-3-sonnet
AI_MAX_TOKENS=1000

# Brand voice enforcement
VOICE_CONSISTENCY_CHECK=True
FORBIDDEN_WORDS_CHECK=True

# SEO keyword optimization
SEO_AUTO_GENERATE=True
SEO_MIN_TITLE_LENGTH=30
SEO_MAX_TITLE_LENGTH=60

# ==============================================================================
# 16. CUSTOMER & LOYALTY
# ==============================================================================
# Loyalty program settings
LOYALTY_PROGRAM_ENABLED=False
LOYALTY_POINTS_MULTIPLIER=1.0

# Customer personas (from 03_Customer_Psychology)
CUSTOMER_PERSONAS=MVQueenCore,MissPrincessFan,VictoriaSoftPower,SephoraPrecision,RunwayModern

# ==============================================================================
# 17. CONTENT & MARKETING
# ==============================================================================
# Email marketing
EMAIL_LIST_ID=YOUR_SHOPIFY_EMAIL_LIST_ID
NEWSLETTER_FREQUENCY=weekly

# Social media accounts
INSTAGRAM_BUSINESS_ACCOUNT_ID=YOUR_INSTAGRAM_ID
TIKTOK_BUSINESS_ACCOUNT_ID=YOUR_TIKTOK_ID
PINTEREST_BUSINESS_ID=YOUR_PINTEREST_ID

# ==============================================================================
# 18. COMPLIANCE & LEGAL
# ==============================================================================
# Privacy & legal
PRIVACY_POLICY_URL=https://mvqueen.com/privacy
TERMS_OF_SERVICE_URL=https://mvqueen.com/terms
RETURN_POLICY_URL=https://mvqueen.com/returns

# GDPR/CCPA compliance
GDPR_COMPLIANCE_MODE=True
CCPA_COMPLIANCE_MODE=True

# ==============================================================================
# 19. DEVELOPMENT ONLY (Never use in production)
# ==============================================================================
# Dry run mode (simulate API calls without making real changes)
DRY_RUN=False

# Verbose logging for debugging
VERBOSE_LOGGING=False

# Use mock data for testing
USE_MOCK_DATA=False

# ==============================================================================
# END OF CONFIGURATION
# ==============================================================================
# Last updated: 2026-06-10
# Format: KEY=VALUE (no quotes needed for simple strings)
# ==============================================================================
